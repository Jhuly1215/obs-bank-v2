# ====== Grafana ======
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CAMBIAR_PASSWORD_SEGURO_EN_PROD

# Puerto expuesto al host para la UI de Grafana
GRAFANA_PORT=3000

# ====== SMTP ======
GF_SMTP_HOST=smtp.gmail.com:587
GF_SMTP_USER=empresa@gmail.com
GF_SMTP_PASSWORD=x x x x x x x x x x x x
GF_SMTP_FROM_ADDRESS=empresav@gmail.com
GF_SMTP_FROM_NAME=Ejemplo Observabilidad

# ====== SQL Poller ======
SQLSERVER_CONN=Server=host.docker.internal,1433;Database=DBNAME;User Id=APPUSER;Password=PASSWORD;Encrypt=True;TrustServerCertificate=True;
SQL_POLLER_INTERVAL=60

# ====== OTLP Collector (ingesta APIs externas) ======
# Puertos que las APIs de produccion (ej: EconetTransacciones) deben apuntar
OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318

# ====== MinIO ======
MINIO_ROOT_USER=obsbank_minio_admin
MINIO_ROOT_PASSWORD=ObsBank2026!

# Buckets requeridos por Loki y Tempo (se crean automáticamente al iniciar)
MINIO_BUCKET_LOKI=loki
MINIO_BUCKET_TEMPO=tempo

# Puertos expuestos al host para MinIO
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ====== Ajustes Avanzados S3 (Opcional) ======
# LOKI_S3_ENDPOINT=minio:9000
# LOKI_S3_REGION=us-east-1
# TEMPO_S3_ENDPOINT=minio:9000
# TEMPO_S3_INSECURE=true

# ====== Active Directory (LDAP) ======
LDAP_BIND_PASSWORD=ContrasenaDelServiceAccountAD

# ====== Recolección de Logs (Alloy) ======
#ESTOY REALIZANDO MIS CAMBIOS ACA AAAAAAAAAAAAAAAAAAAAAAA PROD_LOGS_PATH=/var/log/banco/apis
PROD_LOGS_PATH=./sample-logs  

# Etiqueta de ambiente que aparece en todos los logs de Loki
ALLOY_ENV=prod

# ====== LDAP / Active Directory ======
# Nota: el host del AD se configura directamente en deploy/prod/ldap.prod.toml
# ya que Grafana no soporta interpolación de variables para ese campo en el TOML.

# ====== Notificaciones FCM Bridge ======
BRIDGE_API_KEY=CAMBIAR_KEY_ALEATORIA_LARGA_EN_PROD

# ====== Grafana URL (afecta links en emails y notificaciones FCM) ======
#OJO ESTOY HACINEOD MIS CAMBIOS ACAAAAAAAAAAAAAAAAAAAAAAA Reemplazar con el dominio real o IP del servidor donde corre Grafana
#GF_SERVER_DOMAIN=grafana.banco.local
#GF_SERVER_ROOT_URL=http://grafana.banco.local:3000/

GF_SERVER_DOMAIN=localhost
GF_SERVER_ROOT_URL=http://localhost:3000/

# ====== Retención de Trazas en Tempo ======
# Formato: h=horas. 2160h = 90 días. Ajustar según política del banco.
TEMPO_BLOCK_RETENTION=2160h

# ====== Prometheus Scrape Interval ======
# Frecuencia de recoleccion de metricas. Subir a 30s o 60s en alta carga.
PROM_SCRAPE_INTERVAL=15s