# ====== Versiones ======
OTEL_COLLECTOR_VERSION=0.149.0
PROMETHEUS_VERSION=v3.11.1
LOKI_VERSION=3.7.0
TEMPO_VERSION=2.10.3
GRAFANA_VERSION=12.4.2
ALLOY_VERSION=v1.15.0
REDIS_VERSION=7.4.8-alpine
OPENLDAP_VERSION=1.4.0
OTEL_AGENT_VERSION=latest

# ====== Grafana ======
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Dominio pÃºblico para el Reverse Proxy HTTPS
# Puerto interno para Grafana. IIS redirige HTTPS hacia este puerto local.
GRAFANA_PORT=127.0.0.1:3000
DOMAIN_NAME=obs.ecofuturo.com.bo
GRAFANA_URL=https://obs.ecofuturo.com.bo/
GF_SERVER_DOMAIN=obs.ecofuturo.com.bo
GF_SERVER_ROOT_URL=https://obs.ecofuturo.com.bo/

# ====== SMTP ======
GF_SMTP_HOST=smtp.gmail.com:587
GF_SMTP_USER=empresa@gmail.com
GF_SMTP_PASSWORD=b X X X X X X X X X X X X
GF_SMTP_FROM_ADDRESS=empresa@gmail.com
GF_SMTP_FROM_NAME=EcoFuturo Observability

# ====== SQL Poller ======
# ====== OpenTelemetry Zero-Code Agent ======
OTEL_AGENT_ENDPOINT=http://otel-collector:4317
OTEL_AGENT_LOGS_EXPORT=otlp
OTEL_AGENT_METRICS_EXPORT=otlp
OTEL_AGENT_TRACES_EXPORT=otlp

# ====== OperaciÃ³n ======
ASPNETCORE_ENVIRONMENT=Production
DEMO_API_VERSION=2.0.0
SQL_POLLER_VERSION=2.0.0
SQL_POLLER_INTERVAL=60

SQLSERVER_CONN=Server=host.docker.internal,1433;Database=EconetTransacciones;User Id=appuser;Password=admin;Encrypt=True;TrustServerCertificate=True;

# ====== OTLP Collector (ingesta APIs externas) ======
# Puertos que las APIs de produccion (ej: EconetTransacciones) deben apuntar
OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318


# ====== Ajustes Avanzados S3 (MinIO Remoto) ======
# MinIO estÃ¡ alojado en otro servidor con HTTPS habilitado
LOKI_S3_ENDPOINT=minio.ecofuturo.com.bo
LOKI_S3_REGION=us-east-1
LOKI_S3_INSECURE=false
LOKI_S3_BUCKET=loki
LOKI_S3_ACCESS_KEY=admin_ecofuturo
LOKI_S3_SECRET_KEY=PASSWORD_SEGURA
LOKI_S3_SKIP_VERIFY=true

TEMPO_S3_ENDPOINT=minio.ecofuturo.com.bo
TEMPO_S3_INSECURE=false
TEMPO_S3_SKIP_VERIFY=true
TEMPO_S3_BUCKET=tempo
TEMPO_S3_REGION=us-east-1
TEMPO_S3_ACCESS_KEY=admin_ecofuturo
TEMPO_S3_SECRET_KEY=PASSWORD_SEGURA

MINIO_SCHEME=https


# ====== Puertos Internos Tempo ======
TEMPO_HTTP_LISTEN_PORT=3200
TEMPO_GRPC_LISTEN_PORT=4317
TEMPO_HTTP_RECEIVER_PORT=4318
TEMPO_FRONTEND_PORT=9095


# ====== URLs Internas ======
OTEL_COLLECTOR_URL=http://otel-collector:4317
LOKI_URL=http://loki:3100
TEMPO_URL=http://tempo:3200
PROMETHEUS_URL=http://prometheus:9090
REDIS_URL=redis:6379
GRAFANA_URL=https://obs.ecofuturo.com.bo

# ====== Active Directory (LDAP) ======
LDAP_BIND_PASSWORD=GoodNewsEveryone

# ====== RecolecciÃ³n de Logs (Alloy) ======
#ESTOY REALIZANDO MIS CAMBIOS ACA AAAAAAAAAAAAAAAAAAAAAAA PROD_LOGS_PATH=/var/log/banco/apis
PROD_LOGS_PATH=./sample-logs  

# Etiqueta de ambiente que aparece en todos los logs de Loki
# Etiqueta de ambiente que aparece en todos los logs de Loki
ALLOY_ENV=prod

# --- ACTIVE DIRECTORY / LDAP (Local defaults para testeo) ---
LDAP_DOMAIN=planetexpress.com
LDAP_SERVER_HOST=openldap
LDAP_SERVER_PORT=389
LDAP_USE_SSL=false
LDAP_BIND_DN=cn=admin,dc=planetexpress,dc=com

# ====== LDAP / Active Directory ======
# Nota: el host del AD se configura directamente en deploy/prod/ldap.prod.toml
# ya que Grafana no soporta interpolaciÃ³n de variables para ese campo en el TOML.

# ====== Notificaciones FCM Bridge ======
BRIDGE_API_KEY=dev_key_super_secret_123

# ====== Grafana URL (Configurado para HTTPS vÃ­a IIS) ======
# El Proxy Inverso (IIS) recibirÃ¡ en 443 y enviarÃ¡ a Grafana en 3000
GF_SERVER_DOMAIN=obs.ecofuturo.com.bo
GF_SERVER_ROOT_URL=https://obs.ecofuturo.com.bo/
# Puerto interno para Grafana. IIS redirige HTTPS hacia este puerto local.

# ====== RetenciÃ³n de Trazas en Tempo ======
# Formato: h=horas. 2160h = 90 dÃ­as. Ajustar segÃºn polÃ­tica del banco.
TEMPO_BLOCK_RETENTION=2160h

# ====== Prometheus Scrape Interval ======
# Frecuencia de recoleccion de metricas. Subir a 30s o 60s en alta carga.
# ====== RUTAS DE DATOS (Evitar Root) ======
LOKI_STORAGE_DIR=/loki
TEMPO_STORAGE_DIR=/var/tempo
PROMETHEUS_STORAGE_DIR=/prometheus
ALLOY_STORAGE_DIR=/var/lib/alloy/data
MINIO_STORAGE_DIR=/data
OTEL_DOTNET_AUTO_LOG_DIRECTORY=./logs/otel-agent
