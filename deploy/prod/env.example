GRAFANA_ADMIN_PASSWORD=
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
# Luego vendr·n MINIO_ACCESS_KEY / MINIO_SECRET_KEY en Fase 1


# MinIO (local S3 compatible)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

MINIO_BUCKET_LOKI=loki
MINIO_BUCKET_TEMPO=tempo

# Tempo -> MinIO (S3)
TEMPO_S3_BUCKET=tempo
TEMPO_S3_ENDPOINT=minio:9000
TEMPO_S3_ACCESS_KEY=minioadmin
TEMPO_S3_SECRET_KEY=minioadmin
TEMPO_S3_INSECURE=true

# Loki -> MinIO (S3)
LOKI_S3_BUCKET=loki
LOKI_S3_ENDPOINT=http://minio:9000
LOKI_S3_ACCESS_KEY=minioadmin
LOKI_S3_SECRET_KEY=minioadmin
LOKI_S3_REGION=us-east-1