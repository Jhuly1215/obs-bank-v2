# ==========================================================
# EcoMonitor DEV - Configuración centralizada
# ==========================================================

# ==========================================================
# Dominio Grafana DEV
# ==========================================================
DOMAIN_NAME=localhost
GRAFANA_URL=http://localhost:3000/

# ==========================================================
# Versiones
# ==========================================================
OTEL_COLLECTOR_VERSION=0.149.0
PROMETHEUS_VERSION=v3.11.1
LOKI_VERSION=3.7.0
TEMPO_VERSION=2.10.3
GRAFANA_VERSION=12.4.2
ALLOY_VERSION=v1.15.0
REDIS_VERSION=7.4.8-alpine
OPENLDAP_VERSION=1.5.0
OTEL_AGENT_VERSION=1.5.0

# ==========================================================
# Puertos expuestos DEV
# ==========================================================
GRAFANA_PORT=3000
DEMO_API_PORT=5000
FCM_BRIDGE_PORT=5050
LDAP_PORT=389

OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318

# ==========================================================
# Puertos internos Tempo
# ==========================================================
TEMPO_HTTP_LISTEN_PORT=3200
TEMPO_GRPC_LISTEN_PORT=4317
TEMPO_HTTP_RECEIVER_PORT=4318
TEMPO_FRONTEND_PORT=9095

# ==========================================================
# URLs internas Docker
# ==========================================================
OTEL_COLLECTOR_URL=http://otel-collector:4317
OTEL_AGENT_ENDPOINT=http://otel-collector:4317

LOKI_URL=http://loki:3100
TEMPO_URL=http://tempo:3200
PROMETHEUS_URL=http://prometheus:9090
REDIS_URL=redis:6379

# ==========================================================
# OpenTelemetry Zero-Code Agent
# ==========================================================
OTEL_AGENT_LOGS_EXPORT=otlp
OTEL_AGENT_METRICS_EXPORT=otlp
OTEL_AGENT_TRACES_EXPORT=otlp
OTEL_DOTNET_AUTO_LOG_DIRECTORY=./logs/otel-agent

# ==========================================================
# Operación
# ==========================================================
ASPNETCORE_ENVIRONMENT=Development

DEMO_API_VERSION=2.0.0
SQL_POLLER_VERSION=2.0.0
SQL_POLLER_INTERVAL=60

# ==========================================================
# SQL Server DEV
# Nota: cuando la BD EcoMonitor ya exista, SQLSERVER_CONN debe apuntar a EcoMonitor.
# ==========================================================
SQLSERVER_CONN=Server=host.docker.internal,1433;Database=EcoMonitor;User Id=appuser;Password=admin;Encrypt=True;TrustServerCertificate=True;
ECONET_DB_CONN=Server=host.docker.internal,1433;Database=Econet;User Id=appuser;Password=admin;Encrypt=True;TrustServerCertificate=True;

# ==========================================================
# Grafana DEV
# ==========================================================
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

GF_SMTP_ENABLED=false
GF_AUTH_LDAP_ENABLED=false

# ==========================================================
# SMTP DEV
# Si no usarás correo en DEV, puede quedar deshabilitado arriba.
# ==========================================================
GF_SMTP_HOST=smtp.gmail.com:587
GF_SMTP_USER=jhulsdev@gmail.com
GF_SMTP_PASSWORD=x x x x x x x x x x x x x x x x
GF_SMTP_FROM_ADDRESS=jhulsdev@gmail.com
GF_SMTP_FROM_NAME=EcoMonitor DEV

# ==========================================================
# LDAP DEV / OpenLDAP de prueba
# ==========================================================
LDAP_DOMAIN=planetexpress.com
LDAP_SERVER_HOST=openldap
LDAP_SERVER_PORT=389
LDAP_USE_SSL=false
LDAP_BIND_DN=cn=admin,dc=planetexpress,dc=com
LDAP_BIND_PASSWORD=GoodNewsEveryone
LDAP_SEARCH_BASE=ou=people,dc=planetexpress,dc=com
LDAP_GROUP_ADMIN=cn=admin_staff,ou=groups,dc=planetexpress,dc=com
LDAP_GROUP_VIEWER=cn=ship_crew,ou=groups,dc=planetexpress,dc=com

# ==========================================================
# FCM Bridge DEV
# ==========================================================
BRIDGE_API_KEY=dev_key_super_secret_123
FCM_BRIDGE_NAME=ecomonitor-fcm-bridge
FCM_BRIDGE_VERSION=1.0.0

# ==========================================================
# MinIO DEV
# MinIO corre aparte en el proyecto MinIOServer, en el mismo host físico.
# EcoMonitor se conecta por https://minio.ecofuturo.com.bo usando extra_hosts.
# ==========================================================
MINIO_MC_VERSION=RELEASE.2025-01-17T23-25-50Z

MINIO_SCHEME=https
MINIO_ENDPOINT=minio.ecofuturo.com.bo
MINIO_CONSOLE_ENDPOINT=minio-console.ecofuturo.com.bo

MINIO_ROOT_USER=admin_ecofuturo
MINIO_ROOT_PASSWORD=PASSWORD_SEGURA

MINIO_BUCKET_LOKI=loki
MINIO_BUCKET_TEMPO=tempo

# En DEV se deja true para evitar fallos por certificado local/IIS.
# No significa HTTP; solo permite saltar validación TLS del cliente.
MINIO_MC_INSECURE=true

# ==========================================================
# Loki -> MinIO S3 DEV
# ==========================================================
LOKI_S3_ENDPOINT=minio.ecofuturo.com.bo
LOKI_S3_REGION=us-east-1
LOKI_S3_BUCKET=loki
LOKI_S3_ACCESS_KEY=admin_ecofuturo
LOKI_S3_SECRET_KEY=PASSWORD_SEGURA
LOKI_S3_INSECURE=false
LOKI_S3_SKIP_VERIFY=true
LOKI_RETENTION_PERIOD=2160h
LOKI_STORAGE_DIR=/loki

# ==========================================================
# Tempo -> MinIO S3 DEV
# ==========================================================
TEMPO_S3_ENDPOINT=minio.ecofuturo.com.bo
TEMPO_S3_REGION=us-east-1
TEMPO_S3_BUCKET=tempo
TEMPO_S3_ACCESS_KEY=admin_ecofuturo
TEMPO_S3_SECRET_KEY=PASSWORD_SEGURA
TEMPO_S3_INSECURE=false
TEMPO_S3_SKIP_VERIFY=true
TEMPO_STORAGE_DIR=/var/tempo
TEMPO_BLOCK_RETENTION=2160h

# ==========================================================
# Prometheus / almacenamiento local de contenedores
# ==========================================================
PROMETHEUS_RETENTION=15d
PROMETHEUS_STORAGE_DIR=/prometheus
ALLOY_STORAGE_DIR=/var/lib/alloy/data

# ==========================================================
# Recolección de logs DEV
# ==========================================================
BANK_LOGS_PATH=./sample-logs
ALLOY_ENV=dev